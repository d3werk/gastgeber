{
  "name": "d3-werk/gastgeber",
  "description": "Gastgeberanbieter mit Backend-pflegbaren Merkmal-Icons, Filtermenü, Listen-/Card-Ansicht und OpenStreetMap-Karte auf Basis von EXT:news für TYPO3 CMS.",
  "license": "GPL-2.0-or-later",
  "type": "typo3-cms-extension",
  "keywords": [
    "TYPO3",
    "extension",
    "news",
    "gastgeber",
    "unterkunft",
    "tourismus",
    "filter",
    "merkmale",
    "sys-category",
    "openstreetmap",
    "leaflet",
    "bootstrap"
  ],
  "authors": [
    {
      "name": "d3-werk",
      "homepage": "https://d3-werk.de",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/d3werk/gastgeber",
  "support": {
    "issues": "https://github.com/d3werk/gastgeber/issues",
    "source": "https://github.com/d3werk/gastgeber",
    "docs": "https://github.com/d3werk/gastgeber#readme"
  },
  "require": {
    "php": ">= 8.2 < 8.6",
    "symfony/console": "^5.4 || ^6.4 || ^7.0",
    "typo3/cms-backend": "^13.4.20 || ^14.0",
    "typo3/cms-core": "^13.4.20 || ^14.0",
    "typo3/cms-extbase": "^13.4.20 || ^14.0",
    "typo3/cms-fluid": "^13.4.20 || ^14.0",
    "typo3/cms-frontend": "^13.4.20 || ^14.0",
    "typo3/cms-install": "^13.4.20 || ^14.0",
    "georgringer/news": "^14.0",
    "d3-werk/gastgeber": "^1.5"
  },
  "replace": {
    "typo3-ter/gastgeber": "self.version"
  },
  "suggest": {
    "bk2k/bootstrap-package": "Empfohlen für Bootstrap-5-Markup und die Nutzung im Bootstrap Package Sitepackage.",
    "typo3/cms-seo": "Empfohlen für SEO-Funktionen und Sitemap-Unterstützung im TYPO3-Projekt."
  },
  "autoload": {
    "psr-4": {
      "D3Werk\\Gastgeber\\": "Classes/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "gastgeber"
    }
  }
}
