<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Gastgeberfilter</sheetTitle>
        <type>array</type>
        <el>
          <settings.targetPid>
            <label>Zielseite Gastgeberliste</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
              <suggestOptions>
                <default>
                  <addWhere>AND pages.doktype NOT in (6,199,254)</addWhere>
                </default>
              </suggestOptions>
            </config>
          </settings.targetPid>
          <settings.headline>
            <label>Überschrift</label>
            <config>
              <type>input</type>
            <default>Unterkunft filtern</default>
            </config>
          </settings.headline>
          <settings.types>
            <label>Unterkunftsarten anzeigen</label>
            <config>
              <type>select</type>
              <renderType>selectMultipleSideBySide</renderType>
              <foreign_table>tx_gastgeber_domain_model_type</foreign_table>
              <foreign_table_where>AND {tx_gastgeber_domain_model_type}.{hidden}=0 ORDER BY {tx_gastgeber_domain_model_type}.{sorting},{tx_gastgeber_domain_model_type}.{title}</foreign_table_where>
              <minitems>0</minitems>
              <maxitems>99</maxitems>
              <size>8</size>
            </config>
          </settings.types>
          <settings.featureRoots>
            <label>Merkmalsgruppen anzeigen</label>
            <config>
              <type>select</type>
              <renderType>selectMultipleSideBySide</renderType>
              <foreign_table>tx_gastgeber_domain_model_featuregroup</foreign_table>
              <foreign_table_where>AND {tx_gastgeber_domain_model_featuregroup}.{hidden}=0 ORDER BY {tx_gastgeber_domain_model_featuregroup}.{sorting},{tx_gastgeber_domain_model_featuregroup}.{title}</foreign_table_where>
              <minitems>0</minitems>
              <maxitems>99</maxitems>
              <size>8</size>
            </config>
          </settings.featureRoots>
          <settings.showDistricts>
            <label>Ortsteile anzeigen</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.showDistricts>
        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>
