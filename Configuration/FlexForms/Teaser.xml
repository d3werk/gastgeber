<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Gastgeber-Teaser</sheetTitle>
        <type>array</type>
        <el>
          <settings.storagePid>
            <label>Datensatz-Ordner / Storage PID</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <size>3</size>
              <maxitems>50</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.storagePid>

          <settings.detailPid>
            <label>Detailseite</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
              <suggestOptions>
                <default>
                  <addWhere>AND pages.doktype NOT in (6,199,254)</addWhere>
                </default>
              </suggestOptions>
            </config>
          </settings.detailPid>
          <settings.types>
            <label>Unterkunftsarten einschränken</label>
            <config>
              <type>select</type>
              <renderType>selectMultipleSideBySide</renderType>
              <foreign_table>tx_gastgeber_domain_model_type</foreign_table>
              <foreign_table_where>AND {tx_gastgeber_domain_model_type}.{hidden}=0 ORDER BY {tx_gastgeber_domain_model_type}.{sorting},{tx_gastgeber_domain_model_type}.{title}</foreign_table_where>
              <minitems>0</minitems>
              <maxitems>99</maxitems>
              <size>8</size>
            </config>
          </settings.types>
          <settings.featuredOnly>
            <label>Nur hervorgehobene Gastgeber</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.featuredOnly>
          <settings.itemsPerPage>
            <label>Anzahl</label>
            <config>
              <type>input</type>
            <default>3</default>
            </config>
          </settings.itemsPerPage>
        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>
