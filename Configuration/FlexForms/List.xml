<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Gastgeberliste</sheetTitle>
        <type>array</type>
        <el>
          <settings.storagePid>
            <label>Datensatz-Ordner / Storage PID</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <size>3</size>
              <maxitems>50</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.storagePid>
          <settings.types>
            <label>Unterkunftsarten einschränken</label>
            <config>
              <type>select</type>
              <renderType>selectMultipleSideBySide</renderType>
              <foreign_table>tx_gastgeber_domain_model_type</foreign_table>
              <foreign_table_where>AND {tx_gastgeber_domain_model_type}.{hidden}=0 ORDER BY {tx_gastgeber_domain_model_type}.{sorting},{tx_gastgeber_domain_model_type}.{title}</foreign_table_where>
              <minitems>0</minitems>
              <maxitems>99</maxitems>
              <size>8</size>
            </config>
          </settings.types>
          <settings.featureRoots>
            <label>Merkmale im Filter einschränken</label>
            <config>
              <type>select</type>
              <renderType>selectMultipleSideBySide</renderType>
              <foreign_table>tx_gastgeber_domain_model_featuregroup</foreign_table>
              <foreign_table_where>AND {tx_gastgeber_domain_model_featuregroup}.{hidden}=0 ORDER BY {tx_gastgeber_domain_model_featuregroup}.{sorting},{tx_gastgeber_domain_model_featuregroup}.{title}</foreign_table_where>
              <minitems>0</minitems>
              <maxitems>99</maxitems>
              <size>8</size>
            </config>
          </settings.featureRoots>
          <settings.itemsPerPage>
            <label>Anzahl pro Seite</label>
            <config>
              <type>input</type>
            <default>24</default>
            </config>
          </settings.itemsPerPage>
          <settings.defaultView>
            <label>Standardansicht</label>
            <config>
              <type>select</type>
              <renderType>selectSingle</renderType>
              <items>
                <numIndex index="0">
                  <label>Cards</label><value>cards</value>
                </numIndex>
                <numIndex index="1">
                  <label>Liste</label><value>list</value>
                </numIndex>
                <numIndex index="2">
                  <label>Karte</label><value>map</value>
                </numIndex>
              </items>
            </config>
          </settings.defaultView>
          <settings.showFilter>
            <label>Filterspalte anzeigen</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.showFilter>
          <settings.showMap>
            <label>Kartenansicht aktivieren</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.showMap>
          <settings.showViewSwitch>
            <label>Ansicht-Umschalter anzeigen</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.showViewSwitch>
          <settings.featureConjunction>
            <label>Logik bei mehreren Merkmalen</label>
            <config>
              <type>select</type>
              <renderType>selectSingle</renderType>
              <items>
                <numIndex index="0">
                  <label>Alle ausgewählten Merkmale müssen vorhanden sein</label><value>and</value>
                </numIndex>
                <numIndex index="1">
                  <label>Mindestens eines der Merkmale muss vorhanden sein</label><value>or</value>
                </numIndex>
              </items>
            </config>
          </settings.featureConjunction>
          <settings.detailPid>
            <label>Detailseite</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
              <suggestOptions>
                <default>
                  <addWhere>AND pages.doktype NOT in (6,199,254)</addWhere>
                </default>
              </suggestOptions>
            </config>
          </settings.detailPid>
        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>
