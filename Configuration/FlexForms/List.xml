<?xml version="1.0" encoding="utf-8"?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <type>array</type>
                <el>
                    <settings.storagePid>
                        <label>Datensatz-Ordner der Gastgeber</label>
                        <description>Ordner mit Datensätzen vom Typ Gastgeber. Mehrere UIDs kommasepariert.</description>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>1</size>
                            <maxitems>99</maxitems>
                        </config>
                    </settings.storagePid>
                    <settings.categories>
                        <label>Gastgeber-Grundkategorien</label>
                        <description>Optional: Liste nur auf diese Kategorien einschränken.</description>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <itemsProcFunc>D3Werk\Gastgeber\FormEngine\ItemsProcFunc\GastgeberCategoryItems->addItems</itemsProcFunc>
                            <size>8</size>
                            <maxitems>99</maxitems>
                        </config>
                    </settings.categories>
                    <settings.detailPid>
                        <label>Detailseite</label>
                        <description>Seite mit dem Inhaltselement „Gastgeber: Detailansicht“.</description>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>1</size>
                            <maxitems>1</maxitems>
                        </config>
                    </settings.detailPid>
                </el>
            </ROOT>
        </sDEF>
        <display>
            <ROOT>
                <type>array</type>
                <el>
                    <settings.defaultView>
                        <label>Standardansicht</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0"><label>Cards</label><value>cards</value></numIndex>
                                <numIndex index="1"><label>Liste</label><value>list</value></numIndex>
                                <numIndex index="2"><label>Karte</label><value>map</value></numIndex>
                            </items>
                            <default>cards</default>
                        </config>
                    </settings.defaultView>
                    <settings.showViewSwitch>
                        <label>Ansichtsauswahl anzeigen</label>
                        <config><type>check</type><renderType>checkboxToggle</renderType><default>1</default></config>
                    </settings.showViewSwitch>
                    <settings.itemsPerPage>
                        <label>Maximale Anzahl Gastgeber</label>
                        <config><type>number</type><default>24</default></config>
                    </settings.itemsPerPage>
                </el>
            </ROOT>
        </display>
        <filter>
            <ROOT>
                <type>array</type>
                <el>
                    <settings.showFilter>
                        <label>Filter links in dieser Listenansicht anzeigen</label>
                        <config><type>check</type><renderType>checkboxToggle</renderType><default>1</default></config>
                    </settings.showFilter>
                    <settings.filterHeadline>
                        <label>Filter-Überschrift</label>
                        <config><type>input</type><eval>trim</eval><default>Unterkunft filtern</default></config>
                    </settings.filterHeadline>
                    <settings.filterIntroText>
                        <label>Filter-Einleitung</label>
                        <config><type>text</type><rows>3</rows></config>
                    </settings.filterIntroText>
                    <settings.filterRootCategories>
                        <label>Filter-Wurzelkategorien</label>
                        <description>Leer lassen, um den kompletten Gastgeber-Baum zu verwenden. Sonst z. B. „Merkmale“, „Gastgeber-Art“ oder „Zielgruppen“ auswählen.</description>
                        <config>
                            <type>select</type>
                            <renderType>selectMultipleSideBySide</renderType>
                            <itemsProcFunc>D3Werk\Gastgeber\FormEngine\ItemsProcFunc\GastgeberCategoryItems->addItems</itemsProcFunc>
                            <size>10</size>
                            <maxitems>99</maxitems>
                        </config>
                    </settings.filterRootCategories>
                    <settings.categoryConjunction>
                        <label>Filterlogik bei mehreren Merkmalen</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0"><label>ODER – ein Merkmal reicht</label><value>or</value></numIndex>
                                <numIndex index="1"><label>UND – alle Merkmale müssen passen</label><value>and</value></numIndex>
                            </items>
                            <default>or</default>
                        </config>
                    </settings.categoryConjunction>
                    <settings.resetLabel>
                        <label>Beschriftung Zurücksetzen</label>
                        <config><type>input</type><eval>trim</eval><default>Alle Filter zurücksetzen</default></config>
                    </settings.resetLabel>
                </el>
            </ROOT>
        </filter>
    </sheets>
</T3DataStructure>
