<?xml version="1.0" encoding="UTF-8"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Detailquelle</sheetTitle>
        <type>array</type>
        <el>
          <settings.singleNews>
            <label>Fester Gastgeber-Datensatz</label>
            <description>Normalerweise leer lassen. Die Detailseite erhält den Gastgeber über den Link aus der Liste. Nur verwenden, wenn diese Seite immer einen festen Gastgeber zeigen soll.</description>
            <config>
              <type>group</type>
              <allowed>tx_news_domain_model_news</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.singleNews>
          <settings.startingpoint>
            <label>Datensatz-Ordner der Gastgeber</label>
            <description>Ordner oder Seite auswählen, in der die Gastgeber-News-Datensätze liegen.</description>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <size>3</size>
              <maxitems>50</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.startingpoint>
          <settings.recursive>
            <label>Unterordner einbeziehen</label>
            <config>
              <type>select</type>
              <renderType>selectSingle</renderType>
              <items>
                <numIndex index="0"><label>Nur ausgewählter Ordner</label><value>0</value></numIndex>
                <numIndex index="1"><label>1 Ebene</label><value>1</value></numIndex>
                <numIndex index="2"><label>2 Ebenen</label><value>2</value></numIndex>
                <numIndex index="3"><label>3 Ebenen</label><value>3</value></numIndex>
                <numIndex index="4"><label>4 Ebenen</label><value>4</value></numIndex>
              </items>
              <default>1</default>
            </config>
          </settings.recursive>
        </el>
      </ROOT>
    </sDEF>
    <navigation>
      <ROOT>
        <sheetTitle>Navigation</sheetTitle>
        <type>array</type>
        <el>
          <settings.listPid>
            <label>Übersichtsseite</label>
            <description>Seite mit „Gastgeber: Übersicht / Liste“. Wird für Zurück-Links und interne Verlinkung verwendet.</description>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.listPid>
          <settings.backPid>
            <label>Separates Zurück-Link-Ziel</label>
            <description>Optional. Nur setzen, wenn der Zurück-Link nicht zur normalen Übersichtsseite führen soll.</description>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.backPid>
          <settings.disableOverrideDemand>
            <label>URL-Parameter für Detailauswahl ignorieren</label>
            <description>Normalerweise aus lassen. Nur aktivieren, wenn ein fester Gastgeber-Datensatz angezeigt werden soll.</description>
            <config>
              <type>check</type>
              <default>0</default>
            </config>
          </settings.disableOverrideDemand>
        </el>
      </ROOT>
    </navigation>
  </sheets>
</T3DataStructure>
