<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Gastgeberdetail</sheetTitle>
        <type>array</type>
        <el>
          <settings.storagePid>
            <label>Datensatz-Ordner / Storage PID</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <size>3</size>
              <maxitems>50</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.storagePid>
          <settings.listPid>
            <label>Übersichtsseite / Zurück-Link</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
              <suggestOptions>
                <default>
                  <addWhere>AND pages.doktype NOT in (6,199,254)</addWhere>
                </default>
              </suggestOptions>
            </config>
          </settings.listPid>
          <settings.mapCenterLat>
            <label>Fallback Kartenmittelpunkt Latitude</label>
            <config>
              <type>input</type>
            <default>53.1966</default>
            </config>
          </settings.mapCenterLat>
          <settings.mapCenterLng>
            <label>Fallback Kartenmittelpunkt Longitude</label>
            <config>
              <type>input</type>
            <default>9.9762</default>
            </config>
          </settings.mapCenterLng>
          <settings.mapZoom>
            <label>Zoom</label>
            <config>
              <type>input</type>
            <default>15</default>
            </config>
          </settings.mapZoom>

          <settings.mapMarkerIconUrl>
            <label>Eigenes Marker-/Standort-Symbol</label>
            <description>Optional: Pfad oder URL zu einem eigenen SVG/PNG, z. B. /fileadmin/undeloh/karte-marker.svg. Leer lassen für das Standard-Symbol der Extension.</description>
            <config>
              <type>input</type>
              <size>50</size>
              <eval>trim</eval>
            </config>
          </settings.mapMarkerIconUrl>

          <settings.mapMarkerIconWidth>
            <label>Marker-Breite in Pixel</label>
            <description>Breite des Symbols. Standard: 38.</description>
            <config>
              <type>number</type>
              <default>38</default>
              <range>
                <lower>1</lower>
                <upper>512</upper>
              </range>
            </config>
          </settings.mapMarkerIconWidth>

          <settings.mapMarkerIconHeight>
            <label>Marker-Höhe in Pixel</label>
            <description>Höhe des Symbols. Standard: 46.</description>
            <config>
              <type>number</type>
              <default>46</default>
              <range>
                <lower>1</lower>
                <upper>512</upper>
              </range>
            </config>
          </settings.mapMarkerIconHeight>

          <settings.mapMarkerIconAnchorX>
            <label>Marker-Anker X</label>
            <description>Horizontaler Punkt des Symbols, der exakt auf der Koordinate liegt. Standard: 19.</description>
            <config>
              <type>number</type>
              <default>19</default>
            </config>
          </settings.mapMarkerIconAnchorX>

          <settings.mapMarkerIconAnchorY>
            <label>Marker-Anker Y</label>
            <description>Vertikaler Punkt des Symbols, der exakt auf der Koordinate liegt. Bei Pin-Symbolen meist die volle Höhe. Standard: 46.</description>
            <config>
              <type>number</type>
              <default>46</default>
            </config>
          </settings.mapMarkerIconAnchorY>

          <settings.mapMarkerPopupAnchorY>
            <label>Popup-Versatz Y</label>
            <description>Vertikaler Popup-Versatz relativ zum Marker-Anker. Standard: -42.</description>
            <config>
              <type>number</type>
              <default>-42</default>
            </config>
          </settings.mapMarkerPopupAnchorY>

        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>
