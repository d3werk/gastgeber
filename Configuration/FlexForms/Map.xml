<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Gastgeberkarte</sheetTitle>
        <type>array</type>
        <el>
          <settings.storagePid>
            <label>Datensatz-Ordner / Storage PID</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <size>3</size>
              <maxitems>50</maxitems>
              <minitems>0</minitems>
            </config>
          </settings.storagePid>

          <settings.detailPid>
            <label>Detailseite für Marker-/Listenlinks</label>
            <config>
              <type>group</type>
              <allowed>pages</allowed>
              <relationship>manyToOne</relationship>
              <size>1</size>
              <maxitems>1</maxitems>
              <minitems>0</minitems>
              <suggestOptions>
                <default>
                  <addWhere>AND pages.doktype NOT in (6,199,254)</addWhere>
                </default>
              </suggestOptions>
            </config>
          </settings.detailPid>
          <settings.mapCenterLat>
            <label>Kartenmittelpunkt Latitude</label>
            <config>
              <type>input</type>
            <default>53.1966</default>
            </config>
          </settings.mapCenterLat>
          <settings.mapCenterLng>
            <label>Kartenmittelpunkt Longitude</label>
            <config>
              <type>input</type>
            <default>9.9762</default>
            </config>
          </settings.mapCenterLng>
          <settings.mapZoom>
            <label>Zoom</label>
            <config>
              <type>input</type>
            <default>13</default>
            </config>
          </settings.mapZoom>
          <settings.showList>
            <label>Liste unter der Karte anzeigen</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.showList>
        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>
