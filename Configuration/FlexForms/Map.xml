<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
  <sheets>
    <sDEF>
      <ROOT>
        <sheetTitle>Gastgeberkarte</sheetTitle>
        <type>array</type>
        <el>
          <settings.storagePid>
            <label>Datensatz-Ordner / Storage PID</label>
            <config>
              <type>input</type>
            </config>
          </settings.storagePid>
          <settings.mapCenterLat>
            <label>Kartenmittelpunkt Latitude</label>
            <config>
              <type>input</type>
            <default>53.1966</default>
            </config>
          </settings.mapCenterLat>
          <settings.mapCenterLng>
            <label>Kartenmittelpunkt Longitude</label>
            <config>
              <type>input</type>
            <default>9.9762</default>
            </config>
          </settings.mapCenterLng>
          <settings.mapZoom>
            <label>Zoom</label>
            <config>
              <type>input</type>
            <default>13</default>
            </config>
          </settings.mapZoom>
          <settings.showList>
            <label>Liste unter der Karte anzeigen</label>
            <config>
              <type>check</type>
              <renderType>checkboxToggle</renderType>
              <default>1</default>
            </config>
          </settings.showList>
        </el>
      </ROOT>
    </sDEF>
  </sheets>
</T3DataStructure>
